# ─────────────────────────────────────────────────────────────────────────────
# SpeakTutor AI — Environment Variables
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For Supabase: use the connection pooler URI (Transaction mode, port 6543)
# Example: postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── AI (OpenAI) ──────────────────────────────────────────────────────────────
# Required for speech recognition (Whisper), AI responses (GPT-4o), and TTS.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Use a long random string (32+ characters).
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ── YooKassa Payments ─────────────────────────────────────────────────────────
# Required to accept real payments.
# Get credentials at: https://yookassa.ru → Integrations → HTTP API
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Return URL after YooKassa payment (must be a publicly accessible HTTPS URL).
# Example: https://your-app.onrender.com/speaktutor/payment/return
YOOKASSA_RETURN_URL=

# Description shown to the payer in YooKassa checkout.
YOOKASSA_PAYMENT_DESCRIPTION=SpeakTutor AI full access

# Public base URL of your site (no trailing slash).
# Example: https://your-app.onrender.com
PUBLIC_SITE_URL=

# ── Optional: Supabase JS client (only if used directly in frontend) ─────────
# The DATABASE_URL above is sufficient for the backend (Drizzle uses it directly).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
